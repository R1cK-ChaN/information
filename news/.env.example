# ── Optional: LLM structured extraction (OpenRouter or compatible) ────────────
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini

# ── Optional: Groq headline summarizer ───────────────────────────────────────
GROQ_API_KEY=

# ── RAG service integration ───────────────────────────────────────────────────
# URL of the running rag-service. When running via Docker Compose on the same
# host, host.docker.internal:8000 is set automatically. Override here if your
# RAG service is on a different host.
RAG_SERVICE_URL=http://host.docker.internal:8000

# API key for the RAG service /admin/collections/sync endpoint (if auth is on).
RAG_API_KEY=

# ── Refresh schedule override (default: 900s = 15 min) ───────────────────────
# REFRESH_INTERVAL_SECONDS=900
