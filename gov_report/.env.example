# LLM extraction (OpenRouter / OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini

# TextIn API (only needed for PDF delegation)
TEXTIN_APP_ID=
TEXTIN_SECRET_CODE=

# HTTP settings
USER_AGENT=gov-report-crawler/0.1
REQUEST_TIMEOUT=30
MAX_CONCURRENT=3
